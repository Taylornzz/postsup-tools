# --- Client env (Vite inlines these into the browser bundle) ---
# Safe to expose: the Supabase anon key is protected by row-level security.
# Optional — without them the app runs fully local (localStorage, password gate).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only env (read by the /api serverless functions) ---
# IMPORTANT: do NOT prefix these with VITE_ — that would leak the secret into the
# client bundle. Set them in the Vercel project (Settings → Environment Variables).
#
# Anthropic API key — powers the Deliverables "AI from spec" ingest (and News later).
# Get one at https://console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=
# Optional model override (the function defaults to claude-sonnet-4-5).
ANTHROPIC_MODEL=
